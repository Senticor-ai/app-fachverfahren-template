{
  "name": "@senticor/fachverfahren-template",
  "version": "0.1.0-rc.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "scripts": {
    "predev": "node ../../scripts/check-dev-dependencies.mjs vite",
    "dev": "node ../../scripts/run-vite-dev.mjs",
    "dev:server": "node --import tsx --watch server/index.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --config-dir ../../.storybook --ci",
    "build:storybook": "storybook build --config-dir ../../.storybook -o ../../storybook-static",
    "test:e2e": "vitest run e2e",
    "test:e2e:postgres": "vitest run e2e/postgres-app-data.e2e.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:storybook": "tsc --noEmit -p tsconfig.storybook.json"
  },
  "dependencies": {
    "@fastify/cors": "catalog:",
    "@fastify/sensible": "catalog:",
    "@fastify/static": "catalog:",
    "@fastify/swagger": "catalog:",
    "@fastify/swagger-ui": "catalog:",
    "@senticor/app-store-postgres": "workspace:*",
    "@senticor/jurisdiction-de": "workspace:*",
    "@senticor/public-sector-sdk": "workspace:*",
    "@senticor/public-sector-ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "catalog:",
    "fastify-plugin": "catalog:",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/react": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "catalog:",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "msw": "2.13.6",
    "shadcn": "^4.11.0",
    "storybook": "^10.4.5",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "vite": "^8.0.16",
    "vitest": "catalog:"
  }
}
