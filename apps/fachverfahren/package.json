{
  "name": "@senticor/fachverfahren",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Klickbare Referenz-App: KOMPOSITION aus @senticor/fachverfahren-kit (fertige Bausteine) + der EINEN LeistungConfig (src/leistung.config.ts — die Austausch-Naht, die der governte Build überschreibt). Keine fachliche Logik hier — nur Routing + die EINE Store-Instanz + die Config.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "emit:contract": "node --experimental-strip-types ./scripts/emit-contract.mts"
  },
  "dependencies": {
    "@senticor/fachverfahren-kit": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^7.9.6",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "fastify": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vite": "^8.0.16"
  }
}
