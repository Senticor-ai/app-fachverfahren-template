{
  "name": "@senticor/fachverfahren",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Klickbare Referenz-App: KOMPOSITION aus @senticor/fachverfahren-kit (fertige Bausteine) + der EINEN LeistungConfig (src/leistung.config.ts — die Austausch-Naht, die der governte Build überschreibt). Keine fachliche Logik hier — nur Routing + die EINE Store-Instanz + die Config.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "emit:contract": "node --experimental-strip-types ./scripts/emit-contract.mts",
    "emit:procedure-contract": "node --experimental-strip-types ./scripts/emit-procedure-contract.mts"
  },
  "dependencies": {
    "@fastify/cookie": "catalog:",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@senticor/app-bff-contracts": "workspace:*",
    "@senticor/app-bff-fastify": "workspace:*",
    "@senticor/app-runtime-fastify": "workspace:*",
    "@senticor/app-store-postgres": "workspace:*",
    "@senticor/fachverfahren-kit": "workspace:*",
    "@senticor/platform-contracts": "workspace:*",
    "@senticor/provider-ai-ollama": "workspace:*",
    "@senticor/provider-local-auth": "workspace:*",
    "@senticor/public-sector-sdk": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "catalog:",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.1",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "6.0.3",
    "vite": "^8.1.4"
  },
  "chos": {
    "runtime": {
      "//": "Laufzeit-Descriptor (DIE EINE Wahrheit, welche Prozesse die App zum Laufen braucht) — vom CHOS-Preview-Boot + Boot-Smoke-Gate gelesen. Neben dem Vite-Frontend hat diese App ein Fastify-Backend (dist-server). Eine App OHNE Backend lässt diesen Block weg → nur das Frontend bootet.",
      "backend": {
        "prepareScript": "build:server",
        "startScript": "start",
        "portEnv": "PORT",
        "defaultPort": 8080,
        "healthPath": "/auth/status",
        "gateProbePath": "/auth/session",
        "proxyTargetEnv": "VITE_DEV_API_PROXY_TARGET",
        "staticDirEnv": "STATIC_DIR",
        "previewEnv": {
          "APP_STORE_MODE": "memory"
        }
      }
    }
  }
}
