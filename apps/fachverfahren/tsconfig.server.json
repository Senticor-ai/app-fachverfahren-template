{
  "extends": "../../tsconfig.strict.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "server",
    "outDir": "dist-server",
    "noEmit": false,
    "types": ["node"],
    "tsBuildInfoFile": "dist-server/.tsbuildinfo",
    "baseUrl": ".",
    "paths": {}
  },
  "references": [
    { "path": "../../packages/app-store-postgres" },
    { "path": "../../packages/platform-contracts" },
    { "path": "../../packages/provider-local-auth" }
  ],
  "include": ["server/**/*.ts"],
  // `*.e2e.test.ts` kreuzt die UI/Server-Grenze: es importiert den `fachverfahren-kit` (jsx/DOM), den diese jsx-freie
  // node-Config nicht bauen kann. Diese Tests werden durch ihre AUSFÜHRUNG in vitest (esbuild) validiert, nicht durch
  // diesen tsc-Lauf. Sie hier auszuschließen hält den Server-Typecheck sauber.
  "exclude": ["server/**/*.e2e.test.ts"]
}
