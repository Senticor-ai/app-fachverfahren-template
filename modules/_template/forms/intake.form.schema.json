{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Replace With Domain Intake",
  "type": "object",
  "required": ["applicantName"],
  "properties": {
    "applicantName": {
      "title": "Name",
      "type": "string",
      "minLength": 1
    },
    "contactPostalCode": {
      "title": "Postleitzahl",
      "type": "string",
      "pattern": "^\\d{5}$",
      "description": "Fünfstellige deutsche Postleitzahl."
    },
    "comment": {
      "title": "Kommentar",
      "type": "string"
    }
  }
}
