# .env.example — Runtime-Konfiguration des Fachverfahren-Templates.
# Diese Datei DOKUMENTIERT die verfügbaren Umgebungsvariablen. Für lokale Overrides nach `.env` kopieren.

# ── Vite-Dev-Server (lokal) ────────────────────────────────────────────────
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173
# Optionaler API-Proxy-Ziel-Origin für den Dev-Server:
# VITE_API_PROXY_TARGET=

# ── Test-Daten-Schicht (Mock Service Worker) ──────────────────────────────
# "enabled" schaltet MSW im Dev-Modus an (Default für eingebettete Preview-Hosts); "disabled" aus.
VITE_API_MOCKING=enabled

# ── Einbettender Preview-/Proxy-Host ───────────────────────────────────────
# base-Pfad, unter dem die App hinter einem einbettenden Proxy gehostet wird (z. B. /preview/<session>/).
# Wird vom Host AUTOMATISCH gesetzt (nicht manuell). Standalone/lokal leer lassen → base = "/".
# APP_PREVIEW_BASE=
# Legacy-Name, aus Kompatibilität weiter akzeptiert (nur setzen, wenn APP_PREVIEW_BASE nicht gesetzt ist):
# CHOS_FLOW_PREVIEW_BASE=

# BASE_URL ist KEIN zu setzender Wert, sondern das Vite-Builtin `import.meta.env.BASE_URL`
# (= der aufgelöste `base` der Config, hier aus APP_PREVIEW_BASE). Nur zur Doku gelistet.
# BASE_URL=/

# ── Static-Server (Container-Laufzeit) ─────────────────────────────────────
# Der abhängigkeitsfreie Static-Server (apps/fachverfahren/scripts/serve.mjs) liefert das gebaute
# SPA-Bundle im Container aus. Werte kommen aus dem Dockerfile; lokal selten nötig.
# PORT — Port, auf dem der Server lauscht (Default 8080).
PORT=8080
# HOST — Bind-Adresse (Default 0.0.0.0, damit der Container von außen erreichbar ist).
HOST=0.0.0.0
# STATIC_DIR — Verzeichnis mit dem gebauten Bundle (Default: ../dist relativ zum Server-Skript).
STATIC_DIR=/app/apps/fachverfahren/dist

# ── Lokale PWA-/Browser-Prüfungen ─────────────────────────────────────────
# Optionaler Chrome-/Chromium-Pfad für `pnpm run check:pwa:browser`, falls die
# automatische Suche den Browser nicht findet.
# CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Optionaler Port für den Fastify-Smoke in `pnpm run check:pwa`.
# PWA_CHECK_PORT=0
# Optionale feste Ports für `pnpm run check:pwa:browser`; leer lassen für freie Ports.
# PWA_BROWSER_APP_PORT=0
# PWA_BROWSER_DEBUG_PORT=0

# ── Domain-API / PROD-Wiring (HttpWorkspacePort) ───────────────────────────
# VITE_API_BASE_URL — ist dies gesetzt, spricht der Client den verfahrensübergreifenden Workspace
# über die server-autoritative Fastify-Domain-API (/api/*) statt über den In-Memory-DEV-Store.
# Leer/ungesetzt = In-Memory-DEV (Seed-Daten). Bsp.: "" (same-origin) oder http://localhost:3000.
# VITE_API_BASE_URL=
# VITE_ENABLED_PROCEDURES — OPTIONAL, mehrere Bürger-Applikationen aus EINER Registry: komma-separierte
# procedureIds, auf die DIESES Portal beschränkt ist (z. B. nur „steuern"). Unset = alle Verfahren der
# Registry. Bsp.: musterantrag  bzw.  steuern,gewerbe
# VITE_ENABLED_PROCEDURES=
# VITE_DEV_ACTOR — OPTIONAL, nur für lokale Full-Stack-Tests mit Header-Auth: setzt die x-*-Header
# des Header-Session-Resolvers (x-actor-id). In echtem PROD leer — die Session kommt aus Cookie/OIDC.
# VITE_DEV_ACTOR=
# VITE_DEV_PERMISSIONS — kommagetrennte Rechte für den DEV-Header-Akteur (Default: der volle SB-Satz
# task.* / case.* / inbox.* / comment.* / audit.read). Nur mit VITE_DEV_ACTOR wirksam.
# VITE_DEV_PERMISSIONS=

# ── Postgres (Persistenz-Adapter + e2e:postgres) ───────────────────────────
# APP_PG_URL — Verbindungs-URL des App-Stores (Pooler-fähig). Fehlt sie, läuft der In-Memory-Store.
# APP_PG_URL=postgresql://user:pass@host:5432/db
# APP_PG_DIRECT_URL — DIREKTE (nicht-Pooler-)URL für Migrationen (node dist/migrate.js). Migrationen
# nie über den Pooler fahren. Bsp.: postgresql://user:pass@host:5432/db
# APP_PG_DIRECT_URL=

# ── UX-Workspace-Skript (scripts/ux-workspace.mjs) ─────────────────────────
# UX_PORT — Port des lokalen UX-Snapshot-Servers (Default frei gewählt).
# UX_PORT=0
# UX_OUT — Ausgabeverzeichnis für die UX-Snapshots/Screenshots.
# UX_OUT=./ux-out

# ── Mandanten-Pinning (Multi-Tenancy, fail-closed) ─────────────────────────
# APP_ALLOWED_TENANTS — komma-separierte Allowlist der Mandanten, die DIESES Deployment bedient. Gesetzt ⇒ eine
# Sitzung mit fremdem tenantId wird server-seitig mit 403 abgewiesen (Defense-in-Depth in der geteilten DB, selbst
# bei zu permissivem IdP). Leer/unset ⇒ keine Einschränkung. Bsp.: t-musterstadt,t-beispielheim
# APP_ALLOWED_TENANTS=
