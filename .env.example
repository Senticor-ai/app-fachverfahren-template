# .env.example — Runtime-Konfiguration des Fachverfahren-Templates.
# Diese Datei DOKUMENTIERT die verfügbaren Umgebungsvariablen. Für lokale Overrides nach `.env` kopieren.

# ── Vite-Dev-Server (lokal) ────────────────────────────────────────────────
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173
# Optionaler API-Proxy-Ziel-Origin für den Dev-Server:
# VITE_API_PROXY_TARGET=

# ── Test-Daten-Schicht (Mock Service Worker) ──────────────────────────────
# "enabled" schaltet MSW im Dev-Modus an (Standard im CHOS-Preview); "disabled" aus.
VITE_API_MOCKING=enabled

# ── CHOS-Preview-Proxy ─────────────────────────────────────────────────────
# base-Pfad, unter dem die App hinter dem CHOS-flow-server gehostet wird (/flow/preview/<session>/).
# Wird vom flow-server AUTOMATISCH gesetzt (nicht manuell). Standalone/lokal leer lassen → base = "/".
# CHOS_FLOW_PREVIEW_BASE=

# BASE_URL ist KEIN zu setzender Wert, sondern das Vite-Builtin `import.meta.env.BASE_URL`
# (= der aufgelöste `base` der Config, hier aus CHOS_FLOW_PREVIEW_BASE). Nur zur Doku gelistet.
# BASE_URL=/

# ── Static-Server (Container-Laufzeit) ─────────────────────────────────────
# Der abhängigkeitsfreie Static-Server (apps/fachverfahren/scripts/serve.mjs) liefert das gebaute
# SPA-Bundle im Container aus. Werte kommen aus dem Dockerfile; lokal selten nötig.
# PORT — Port, auf dem der Server lauscht (Default 8080).
PORT=8080
# HOST — Bind-Adresse (Default 0.0.0.0, damit der Container von außen erreichbar ist).
HOST=0.0.0.0
# STATIC_DIR — Verzeichnis mit dem gebauten Bundle (Default: ../dist relativ zum Server-Skript).
STATIC_DIR=/app/apps/fachverfahren/dist
