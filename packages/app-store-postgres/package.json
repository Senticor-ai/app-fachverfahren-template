{
  "name": "@senticor/app-store-postgres",
  "version": "0.1.0-rc.1",
  "license": "EUPL-1.2",
  "author": "Senticor GmbH",
  "homepage": "https://github.com/Senticor-ai/app-fachverfahren-template#readme",
  "bugs": "https://github.com/Senticor-ai/app-fachverfahren-template/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Senticor-ai/app-fachverfahren-template.git",
    "directory": "packages/app-store-postgres"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "senticor-db-migrate": "./dist/migrate.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "node dist/migrate.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "fractional-indexing": "^4.0.0",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "typescript": "6.0.3",
    "vitest": "catalog:"
  }
}
