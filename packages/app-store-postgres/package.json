{
  "name": "@senticor/app-store-postgres",
  "version": "0.1.0-rc.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "senticor-db-migrate": "./dist/migrate.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "node dist/migrate.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "pg": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
