{
  "name": "@senticor/fachverfahren-kit",
  "version": "0.1.0",
  "description": "Verifizierter, komponentenbasierter Kit für kommunale Fachverfahren (Tailwind + shadcn/ui). Fertige Bausteine + LeistungConfig-Vertrag — die Generierung liefert nur die Config, die UX entsteht immer identisch + geprüft.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./leistungen/*": "./src/leistungen/*.ts",
    "./styles.css": "./src/styles.css",
    "./tailwind-preset.cjs": "./tailwind-preset.cjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "lucide-react": "^1.17.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-tabs": "^1.1.15",
    "react-resizable-panels": "^2.1.7",
    "typescript": "catalog:"
  },
  "dependencies": {
    "zustand": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "lucide-react": "^1 || ^0.4",
    "@radix-ui/react-slot": "^1",
    "@radix-ui/react-label": "^2",
    "@radix-ui/react-checkbox": "^1",
    "@radix-ui/react-select": "^2",
    "@radix-ui/react-separator": "^1",
    "@radix-ui/react-scroll-area": "^1",
    "@radix-ui/react-tabs": "^1",
    "react-resizable-panels": "^2 || ^3"
  }
}
