{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://senticor.local/schemas/agent-run-report.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "task",
    "taskHash",
    "selectedInstructionHashes",
    "filesChanged",
    "commandsExecuted",
    "acceptanceCriteria"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "runId": { "type": "string" },
    "task": { "type": "string" },
    "taskHash": { "type": "string" },
    "selectedInstructionHashes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "filesChanged": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "commandsExecuted": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "command", "cwd"],
        "properties": {
          "id": { "type": "string" },
          "command": { "type": "string" },
          "cwd": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "plannedCommands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "command", "cwd", "writes"],
        "properties": {
          "id": { "type": "string" },
          "command": { "type": "string" },
          "cwd": { "type": "string" },
          "writes": { "type": "boolean" },
          "expectedArtifacts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "followUpChecks": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "tests"],
        "properties": {
          "id": { "type": "string" },
          "tests": { "type": "array", "items": { "type": "string" } },
          "text": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "externalSources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sourceId"],
        "properties": {
          "sourceId": { "type": "string" },
          "provenancePath": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "extensions": { "type": "object" }
  },
  "additionalProperties": true
}
