{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://senticor.local/schemas/app-spec.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "displayName",
    "module",
    "personas",
    "roles",
    "journeys",
    "acceptanceCriteria",
    "dataClassifications",
    "requiredCapabilities",
    "permittedExternalSources",
    "routes",
    "workflows",
    "domainVocabulary"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "id": { "type": "string" },
    "displayName": { "type": "string" },
    "module": {
      "type": "object",
      "required": ["id", "destination", "owner", "lifecycle", "riskClass"],
      "properties": {
        "id": { "type": "string" },
        "destination": { "type": "string", "pattern": "^modules/" },
        "owner": { "type": "string" },
        "lifecycle": { "type": "string" },
        "riskClass": { "type": "string" }
      },
      "additionalProperties": true
    },
    "personas": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "roles": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "journeys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "surface"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "surface": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "tests"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "tests": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "dataClassifications": { "type": "array", "items": { "type": "string" } },
    "requiredCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "permittedExternalSources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "surface"],
        "properties": {
          "path": { "type": "string" },
          "surface": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "workflows": { "type": "array", "items": { "type": "string" } },
    "fim": {
      "type": "object",
      "required": ["sourceId", "rootId"],
      "properties": {
        "sourceId": { "type": "string" },
        "rootId": { "type": "string" },
        "services": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "domainVocabulary": { "type": "array", "items": { "type": "string" } },
    "procedure": {
      "type": "object",
      "description": "OPTIONAL: Fall/Dossier-Verfahren (Zustandsmaschine + Rechtsgrundlagen als DATEN). Präsenz markiert eine Dossier-App; Antrag-nur-Apps lassen den Block weg. Durchgesetzt von validateAppSpecShape (das JSON-Schema ist nur Editor-/Doku-Hilfe).",
      "required": [
        "procedureId",
        "version",
        "legalBasisIds",
        "allowedStates",
        "allowedTransitions"
      ],
      "properties": {
        "procedureId": { "type": "string" },
        "version": { "type": "string" },
        "effectiveFrom": { "type": "string" },
        "legalBasisIds": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "bpmnPath": { "type": "string" },
        "allowedStates": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "allowedTransitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["from", "to", "action"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "action": { "type": "string" },
              "requiredPermission": { "type": "string" },
              "requiresFourEyes": { "type": "boolean" },
              "closesCase": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
