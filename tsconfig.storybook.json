{
  "extends": "./tsconfig.strict.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["node", "react", "react-dom", "vite/client"]
  },
  "references": [
    { "path": "packages/public-sector-sdk" },
    { "path": "packages/fachverfahren-kit" },
    { "path": "packages/public-sector-ui" },
    { "path": "jurisdictions/de" }
  ],
  "include": [
    ".storybook/**/*.ts",
    "apps/fachverfahren/src/**/*.stories.ts",
    "apps/fachverfahren/src/**/*.stories.tsx",
    "modules/**/ui/**/*.stories.ts",
    "modules/**/ui/**/*.stories.tsx",
    "modules/**/ui/**/screens.tsx",
    "packages/fachverfahren-kit/src/**/*.stories.ts",
    "packages/fachverfahren-kit/src/**/*.stories.tsx",
    "packages/public-sector-ui/src/**/*.stories.ts",
    "packages/public-sector-ui/src/**/*.stories.tsx"
  ]
}
