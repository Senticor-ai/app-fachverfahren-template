{
  "$comment": "GENERISCHE Gold-Qualitäts-Latte für ein Fachverfahren aus diesem Template. Gegen die TEMPLATE-EIGENEN, geerdeten Gates gemappt (kein LLM-Judge). CHOS measure-build prüft diese Elemente im real gebauten modules/<domain>/. 'sehr-hoch' = alle blocking grün + ≥90% gewichtete Deckung + prodReady.",
  "schemaVersion": "1.0.0",
  "appliesTo": "fachverfahren-oeffentliche-hand",
  "verdictThresholds": { "sehr-hoch": 90, "hoch": 75, "teilweise": 50 },
  "checks": [
    {
      "id": "three-surfaces",
      "weight": 2,
      "blocking": true,
      "label": "3 Surfaces (Bürger/Sachbearbeitung/Aufsicht) mit Routen + Screen-Contracts",
      "groundedBy": "check:domain-contracts + Routen in domain.module.yaml"
    },
    {
      "id": "compiles",
      "weight": 2,
      "blocking": true,
      "label": "Kompiliert (tsc -b grün)",
      "groundedBy": "pnpm run typecheck"
    },
    {
      "id": "module-contract",
      "weight": 2,
      "blocking": true,
      "label": "Modul-Vertrag vollständig (routes/caps/permissions/events/retention/migrations)",
      "groundedBy": "check:module-contracts"
    },
    {
      "id": "no-cross-domain-leak",
      "weight": 1.5,
      "blocking": true,
      "label": "Keine Domänen-Inhalte außerhalb modules/<domain>/",
      "groundedBy": "check:module-boundaries + tests not.toMatch"
    },
    {
      "id": "ux-library-reuse",
      "weight": 1.5,
      "blocking": false,
      "label": "UI komponiert public-sector-ui (kein from-scratch, KERN-Token statt rohe Farben)",
      "groundedBy": "check:storybook + check:css-tokens"
    },
    {
      "id": "bitv-a11y",
      "weight": 1.5,
      "blocking": false,
      "label": "BITV/a11y in Screen-Contracts + Stories (landmarks/keyboard/focus/zoom/states)",
      "groundedBy": "check:domain-contracts + check:storybook (a11y addon)"
    },
    {
      "id": "tariff-as-data",
      "weight": 1.5,
      "blocking": false,
      "label": "Tarife/Sätze/Fristen als Daten (forms/<domain>.rules.json), nicht inline",
      "groundedBy": "Existenz rules.json + berechnung.ts liest sie + tests"
    },
    {
      "id": "four-eyes",
      "weight": 1.5,
      "blocking": true,
      "label": "4-Augen/HITL serverseitig erzwungen (Festsetzung/Befreiung/Ermäßigung)",
      "groundedBy": "test:authorization + routes.ts"
    },
    {
      "id": "ports-not-providers",
      "weight": 1,
      "blocking": false,
      "label": "Fachlogik nutzt platform-contracts Ports, nie Provider direkt",
      "groundedBy": "check:module-boundaries"
    },
    {
      "id": "legal-anchors",
      "weight": 1.5,
      "blocking": false,
      "label": "Rechtsanker (Satzung/KAG/DSGVO) + FIM-Referenzen im Manifest/Compliance",
      "groundedBy": "compliance/profile.example.json + domain.module.yaml fimReferences"
    },
    {
      "id": "ki-transparency",
      "weight": 1,
      "blocking": false,
      "label": "KI assistiv + transparent (Kennzeichnung/Konfidenz/Quelle/Override) oder keine KI",
      "groundedBy": "KiVorschlag-Komposition + screen hcai.controls"
    },
    {
      "id": "tests-grounded",
      "weight": 1.5,
      "blocking": true,
      "label": "Geerdete Tests grün (Berechnung gegen Beispielwerte + Verträge)",
      "groundedBy": "pnpm run test"
    },
    {
      "id": "dev-server",
      "weight": 1,
      "blocking": false,
      "label": "Dev-Server startet, Surfaces klickbar",
      "groundedBy": "pnpm run dev (Vite 5173) + Smoke"
    }
  ]
}
