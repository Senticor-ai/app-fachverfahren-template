# set -e: ein fehlgeschlagenes `check:push` MUSS den Hook stoppen. Ohne es bestimmte das letzte
# Kommando (test:generated-app-ci) den Exit-Status — das self-skippt in Konsumenten (exit 0) und
# könnte ein rotes Push-Gate stillschweigend durchlassen.
set -e

if [ "${HUSKY_SKIP_PRE_PUSH:-0}" = "1" ]; then
  echo "Skipping pre-push gate because HUSKY_SKIP_PRE_PUSH=1."
  exit 0
fi

pnpm run check:push

# Scaffolded-App-Health (core): beweist, dass eine frisch gescaffoldete App IHRE eigene CI besteht —
# das fängt genau den Fehler ab, bei dem die Vorlage grün ist, ein gepushtes generiertes App aber rot.
# Self-Skip in generierten Konsumenten (via .template/lock.json); lokal mit SKIP_SCAFFOLD_CI=1 abschaltbar.
pnpm run test:generated-app-ci
